DATA_BLOCK "DB_GC"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
VAR
    // =============================
    // 外呼按钮输入
    // =============================
    HallUpBtn : ARRAY[1..10] OF BOOL;
    HallDownBtn : ARRAY[1..10] OF BOOL;

    // =============================
    // 内呼指示灯输入
    // LiftCarCall[1,6] = 1号梯6层内呼指示灯
    // =============================
    LiftCarCall : ARRAY[1..3, 1..10] OF BOOL;

    // =============================
    // 群控输出
    // LiftHallUp[1,1] = 1号梯1层上呼
    // LiftHallDown[3,2] = 3号梯2层下呼
    // =============================
    LiftHallUp : ARRAY[1..3, 1..10] OF BOOL;
    LiftHallDown : ARRAY[1..3, 1..10] OF BOOL;

    // =============================
    // 电梯状态输入
    // =============================
    LiftFloor : ARRAY[1..3] OF INT;           // 当前楼层 1~10
    LiftDir : ARRAY[1..3] OF INT;             // -1下行，0停止，1上行
    LiftRunning : ARRAY[1..3] OF BOOL;        // 是否运行中
    LiftDoorOpen : ARRAY[1..3] OF BOOL;       // 是否开门到位
    LiftLoadPercent : ARRAY[1..3] OF INT;     // 载客率 0~100，没有就给0
    LiftPower_kW : ARRAY[1..3] OF REAL;       // 当前功率，没有就给0.0

    // =============================
    // 群控状态
    // =============================
    LiftGroupEnable : ARRAY[1..3] OF BOOL;    // 是否加入群控
    LiftLocked : ARRAY[1..3] OF BOOL;         // 是否锁梯
    LiftDisabled : ARRAY[1..3] OF BOOL;       // 是否临时禁用

    // 0：普通全区
    // 1：上班上行高峰
    // 2：下班下行高峰
    // 3：午餐高峰
    // 4：固定三分区
    GroupMode : INT;

    // =============================
    // 乘梯时间统计输入
    // 暂时没有就保持默认 FALSE / 0.0
    // =============================
    RideFinishPulse : ARRAY[1..3] OF BOOL;
    RideTimeSample_s : ARRAY[1..3] OF REAL;

    // =============================
    // 群控输出结果 / 统计结果
    // =============================
    AssignedLiftUp : ARRAY[1..10] OF INT;
    AssignedLiftDown : ARRAY[1..10] OF INT;

    LiftTaskCount : ARRAY[1..3] OF INT;
    AheadTaskCountOut : ARRAY[1..3] OF INT;

    AvgWait_s : REAL;
    CurrentAvgWait_s : REAL;
    CurrentWaitingCount : INT;

    LongWaitRatePercent : REAL;
    AvgRideTime_s : REAL;

    LiftEfficiencyPercent : ARRAY[1..3] OF REAL;
    SystemEmptyRatePercent : REAL;

    LiftEnergy_kWh : ARRAY[1..3] OF REAL;
    SystemEnergy_kWh : REAL;
END_VAR

BEGIN
    LiftGroupEnable[1] := TRUE;
    LiftGroupEnable[2] := TRUE;
    LiftGroupEnable[3] := TRUE;

    LiftLocked[1] := FALSE;
    LiftLocked[2] := FALSE;
    LiftLocked[3] := FALSE;

    LiftDisabled[1] := FALSE;
    LiftDisabled[2] := FALSE;
    LiftDisabled[3] := FALSE;

    GroupMode := 0;

    LiftLoadPercent[1] := 0;
    LiftLoadPercent[2] := 0;
    LiftLoadPercent[3] := 0;

    LiftPower_kW[1] := 0.0;
    LiftPower_kW[2] := 0.0;
    LiftPower_kW[3] := 0.0;
END_DATA_BLOCK