      "1号梯轿内选层按钮3" : Bool;
      "1号梯轿内选层按钮4" : Bool;
      "1号梯轿内选层按钮5" : Bool;
      "1号梯轿内选层按钮6" : Bool;
      "1号梯轿内开门按钮" : Bool;
      "1号梯轿内关门按钮" : Bool;
      "1号梯光幕信号" : Bool;
